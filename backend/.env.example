# Copy to .env and fill in values. Never commit .env.

# Required for library map search (Places API — New). Create a key in Google Cloud Console
# and enable "Places API (New)" (and billing if Google requires it for your project).
GOOGLE_PLACES_API_KEY=

# Optional: defaults when the user does not share location (NYC World Trade Center area).
# DEFAULT_MAP_LAT=40.712746
# DEFAULT_MAP_LNG=-74.013427

# PORT=4001
# DATA_FILE=
