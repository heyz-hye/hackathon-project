# --- Server ---
PORT=4001

# Optional: JSON store path for generic /api CRUD routes
# DATA_FILE=./data/data.json

# --- Google Places (existing library map) ---
GOOGLE_PLACES_API_KEY=your_google_cloud_api_key_with_places_enabled

# Default map center when the client does not send coordinates (World Trade Center).
# DEFAULT_MAP_LAT=40.712746
# DEFAULT_MAP_LNG=-74.013427

# --- SerpApi (Google Events engine) ---
# https://serpapi.com/manage-api-key
SERPAPI_API_KEY=your_serpapi_key

# Default SerpApi `q` when the client omits a query string.
# DEFAULT_EVENTS_QUERY=Events in New York

# Default search radius in miles (map circle + server-side distance filter).
# DEFAULT_EVENTS_RADIUS_MILES=8

# --- Supabase (Postgres via service role — server only, never expose in the browser) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Auth (JWT for /api/auth/* session tokens) ---
JWT_SECRET=use_a_long_random_string_in_production
# JWT_EXPIRES_IN=7d

# --- Gemini (Derry Ai chat — server only; get a key at https://aistudio.google.com/apikey ) ---
GEMINI_API_KEY=your_gemini_api_key
# Optional: model id (default: gemini-1.5-flash — separate free-tier quota from gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash
