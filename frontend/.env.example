# Copy to `.env.local` for local development.

# Backend base URL (no trailing slash). The Next.js app calls this for auth, budget, events, libraries, and Zillow routes.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4001

# --- Keys the backend needs (set these in `backend/.env`, not here) ---
#
# SERPAPI_API_KEY              — SerpApi Google Events (https://serpapi.com/)
# SUPABASE_URL                 — Project URL from Supabase Settings → API
# SUPABASE_SERVICE_ROLE_KEY    — Service role secret (server-only; never commit real values)
# JWT_SECRET                   — Signs login session tokens for the Express API
# GOOGLE_PLACES_API_KEY        — Google Cloud key with Places API (New) for the library map
#
# See `backend/.env.example` for a full list and defaults.
